terraform.tfvars
*.auto.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc

# Private keys
*.pem
*.key
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
